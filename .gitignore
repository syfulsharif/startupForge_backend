# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Local env files (highly sensitive)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup
*.env
# Ensure we don't accidentally ignore .env.example
!.env.example

# Debug and runtime logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage
.grunt

# Bower dependency directory
bower_components

# node-gyp build folder
build/Release

# Optional npm/yarn cache directory
.npm
.yarn-integrity
.eslintcache
.stylelintcache

# serverless session files
.serverless/

# Operating System Files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Icon?

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw*
